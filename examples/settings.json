{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python3 ~/.claude/hooks/session-recorder/session_start.py"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 ~/.claude/hooks/session-recorder/stop.py"
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "python3 ~/.claude/hooks/session-recorder/pre_compact.py"
      }
    ]
  }
}
